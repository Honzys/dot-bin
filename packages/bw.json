{
  "name": "bw",
  "repo": "bitwarden/clients",
  "tag_prefix": "cli-v",
  "format": "zip",
  "output_binaries": ["bw"],
  "architectures": {
    "x86_64": {
      "asset_pattern": "bw-linux-{version}.zip",
      "extract_path": "bw"
    },
    "arm64": {
      "asset_pattern": "bw-linux-arm64-{version}.zip",
      "extract_path": "bw"
    }
  }
}
