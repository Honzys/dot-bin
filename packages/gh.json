{
  "name": "gh",
  "repo": "cli/cli",
  "tag_prefix": "v",
  "format": "tarball",
  "output_binaries": ["gh"],
  "checksum": {
    "asset": "gh_{version}_checksums.txt",
    "algorithm": "sha256"
  },
  "architectures": {
    "x86_64": {
      "asset_pattern": "gh_{version}_linux_amd64.tar.gz",
      "extract_path": "*/bin/gh"
    },
    "arm64": {
      "asset_pattern": "gh_{version}_linux_arm64.tar.gz",
      "extract_path": "*/bin/gh"
    }
  }
}
